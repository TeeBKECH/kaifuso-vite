//- @title: Страницы
//- @description: Ссылки на сверстанные страницы и черновики
//- @page_class: links
//- @has_intro: false
extends ../layouts/default.pug

block content
  -
    const linksPages = [
      { link: '/main.html', ver: 100, title: 'Главная', note: 'Atmospheric: тёплый курсор + warm-glow с задержкой, затемнение фона hero «свечой», 4-конечные мерцающие звёзды, scroll-parallax фона и медиа клуба, 3D tilt медиа, stagger-появление карточек афиши, Lenis smooth scroll. Эффекты — глобально на всём сайте.' },
      { link: '/main-lite.html', ver: 100, title: 'Главная (lite)', note: 'Облегчённая версия Atmospheric: без fog (.page-intro::after) и без мерцающих звёзд в hero, warm-glow уменьшен с 400px до 300px и менее насыщенный, dim-«свеча» светлее (0.55 вместо 0.78). Курсор, parallax, hero fade-up и tilt — на месте.' },
      { link: '/main-lite-particles.html', ver: 100, title: 'Главная (lite + particles)', note: 'lite-Atmospheric + интерактивные частицы в hero (particles.js): тёплые искры с тонкими линиями между ними, тянутся к курсору на hover, по клику добавляются новые. Загружается только на этой странице.' },
      { link: '/main-lite-leaves.html', ver: 100, title: 'Главная (lite + leaves)', note: 'lite-Atmospheric + падающие листья в hero (sparticles): три стилизованных листа в тёплой палитре, медленное падение с боковым ветерком и вращением. Loading on-demand.' },
      { link: '/about.html', ver: 100, title: 'О нас', note: 'PageIntro-миксин, 3 контент-блока, арт-баннер с оверлеями, gallery-swiper и переиспользуемая секция контактов.' },
      { link: '/menu.html', ver: 100, title: 'Меню', note: 'Hero и три карточки категорий: меню блюд, винная карта, барное меню.' },
      { link: '/menu-detail.html', ver: 100, title: 'Меню (внутренняя)', note: 'Hero, grid-таблица позиций (адаптив: на mobile превращается в карточки) и форма бронирования (ACF repeater-ready).' },
      { link: '/events.html', ver: 100, title: 'Афиша', note: 'Hero, фильтры, карточки-афиша через отдельный миксин, футер и пагинация. Карточки адаптированы под мобильные.' },
      { link: '/blog.html', ver: 100, title: 'Блог', note: 'Разводящая в духе афиши: сетка 3×N, карточка с фото сверху, мета, пагинация и «Загрузить еще». Кнопка-стрелка «Подробнее» вынесена в миксин Button (модификатор link-arrow).' },
      { link: '/event.html', ver: 100, title: 'Событие', note: 'Hero, постер, форма бронирования с выбором канала связи, блок описания и swiper «Другие события».' },
      { link: '/contacts.html', ver: 100, title: 'Контакты', note: 'Контактная информация и форма.' },
      { link: '/404.html', ver: 100, title: '404', note: 'Страница ошибки по дизайну Figma 2002:5788.' },
      { link: '/privacy.html', ver: 100, title: 'Политика конфиденциальности', note: 'Типовая структура single: PageHero, типографика под Gutenberg.' },
      { link: '/single.html', ver: 100, title: 'Запись блога', note: 'PageHero, типографика под Gutenberg (.entry-content), оглавление, swiper «Похожие записи». Контент включает примеры всех типов: параграфы, заголовки, списки, ссылки, жирный/наклонный текст.' },
    ]
    const totalVer = linksPages.reduce((acc, p) => acc + p.ver, 0)
    const avgVer = linksPages.length ? Math.round(totalVer / linksPages.length) : 0
    const activeCount = linksPages.filter((p) => p.ver > 0).length

  section.links
    .container
      .links_intro
        h3.title.title-h3 Страницы
        p.links_note
          | Реестр ссылок для сверки с макетом Figma.
          |
          span.links_note-accent Ниже — краткое описание и ориентировочный процент готовности.

      .links_stats
        .links_stat
          span.links_stat-value= linksPages.length
          p.links_stat-label Страниц в списке
        .links_stat
          span.links_stat-value= `${avgVer}%`
          p.links_stat-label Средняя готовность
        .links_stat
          span.links_stat-value= activeCount
          p.links_stat-label С ненулевым прогрессом

      .links_items
        each pg, i in linksPages
          +Link({ num: i + 1, link: pg.link, title: pg.title, ver: pg.ver, note: pg.note })
