//- @title: Главная
//- @description: KAIFUSO — ресторан-клуб с авторской азиатской кухней
//- @page_class: index
extends ../layouts/default.pug

block content
  -
    const afishaCards = [
      {
        date: '22 марта',
        time: 'Сбор гостей в 20:00',
        title: 'PERFOMANCE<br>SHOW',
        text: 'Особенный вечер, в котором аутентичная кухня, атмосфера и внимание к деталям соединяются в единое впечатление',
        lineup: 'LOVA SHOW, DJ BLANC',
        image: 'assets/img/kaifuso/main/afisha-main.jpg'
      },
      {
        date: '18/03',
        time: 'Сбор гостей в 22:00',
        title: 'THE GREAT<br>SHOW',
        text: 'Особенный вечер, в котором аутентичная кухня, атмосфера и внимание к деталям соединяются в единое впечатление',
        lineup: 'DJ BLANC',
        image: 'assets/img/kaifuso/main/afisha-card-3.jpg'
      },
      {
        date: '31/12',
        time: 'Сбор гостей в 22:00',
        title: 'НОВОГОДНЯЯ<br>НОЧЬ 2026',
        text: 'Особенный вечер, в котором аутентичная кухня, атмосфера и внимание к деталям соединяются в единое впечатление',
        lineup: 'ANNA ASTI, ASET',
        image: 'assets/img/kaifuso/main/afisha-card-2.jpg'
      }
    ]

    const gallerySlides = [
      'assets/img/kaifuso/main/gallery-1.jpg',
      'assets/img/kaifuso/main/gallery-1.jpg',
      'assets/img/kaifuso/main/gallery-1.jpg'
    ]

    const contactsSection = {
      rootClass: 'contacts home_contacts',
      withHero: false,
      heroTitle: 'КОНТАКТЫ',
      subtitle: '',
      title: 'Забронировать стол',
      fieldMode: 'contacts',
      privacyVariant: 'full',
      buttonText: 'Забронировать стол'
    }

  +PageIntro({
    mediaType: 'image',
    mediaSrc: 'assets/img/kaifuso/main/hero.jpg',
    kicker: 'Азиатский ресторан-клуб',
    title: 'KAIFUSO',
    text: 'Ресторан-клуб с авторской азиатской кухней, живой музыкой и атмосферой, которую сложно забыть. Место, куда хочется возвращаться.',
    buttonText: 'Забронировать',
    buttonStyles: ['ghost-gold', 'lg'],
    rootClass: 'home-hero',
    actionModal: 'modal-form',
    overlay: true
  })

  section.home-about(aria-labelledby='home-about-title')
    .container.home-about_top
      .home-about_decor.home-about_decor--left(aria-hidden='true')
        img(src='assets/img/kaifuso/main/about-left.png' alt='')
      .home-about_decor.home-about_decor--right(aria-hidden='true')
        img(src='assets/img/kaifuso/main/about-right-bird.png' alt='')
      .home-about_content
        h2#home-about-title.title.title-h2.home-about_title мир изысканных вкусов
        p.home-about_text KAIFUSO — это ресторан и клубное пространство, в котором гастрономия, эстетика и атмосфера соединяются в единое впечатление. Здесь важна не только кухня, но и то, как вы себя чувствуете в моменте — от первого шага в зал до последних минут вечера.
        p.home-about_text Авторская кухня, выверенная подача и внимательное отношение к деталям формируют основу опыта, в котором вкус, визуальная эстетика и сервис работают как единое целое. Пространство продумано так, чтобы создавать ощущение уюта, приватности и одновременно — легкой динамики живого города.
        p.home-about_text Это пространство, куда приходят не только за ужином, а за состоянием.
    .home-about_gallery
      .home-about_photos
        .home-about_photo
          img(src='assets/img/kaifuso/about/interior.jpg' alt='Интерьер KAIFUSO')
        .home-about_photo
          img(src='assets/img/kaifuso/about/kitchen.jpg' alt='Интерьер KAIFUSO')
        .home-about_photo
          img(src='assets/img/kaifuso/about/club.jpg' alt='Интерьер KAIFUSO')
        .home-about_photo
          img(src='assets/img/kaifuso/about/hero.jpg' alt='Интерьер KAIFUSO')
      .home-about_nav.swiper_nav
        button.swiper_nav_item.swiper_nav_item-prev.home-about_nav-prev(type='button' aria-label='Назад')
          span.gallery_nav_arrow.gallery_nav_arrow--left(aria-hidden='true')
        button.swiper_nav_item.swiper_nav_item-next.home-about_nav-next(type='button' aria-label='Вперед')
          span.gallery_nav_arrow.gallery_nav_arrow--right(aria-hidden='true')

  section.home-afisha(aria-labelledby='home-afisha-title')
    .container.home-afisha_head
      h2#home-afisha-title.title.title-h2.home-afisha_title Афиша
      .home-afisha_actions
        +Button('Все события', ['ghost-gold', 'sm'])
        .home-afisha_nav.swiper_nav
          button.swiper_nav_item.swiper_nav_item-prev.home-afisha_nav-prev(type='button' aria-label='Назад')
            span.gallery_nav_arrow.gallery_nav_arrow--left(aria-hidden='true')
          button.swiper_nav_item.swiper_nav_item-next.home-afisha_nav-next(type='button' aria-label='Вперед')
            span.gallery_nav_arrow.gallery_nav_arrow--right(aria-hidden='true')
    .container
      .home-afisha_slider
        each item, idx in afishaCards
          article.home-afisha_card(data-afisha-card data-card-index=idx class=idx === 0 ? 'home-afisha_card--active' : '')
            .home-afisha_card-media
              img(src=item.image alt=item.title)
            .home-afisha_card-body
              .home-afisha_card-meta
                span= item.date
                span.home-afisha_card-meta-dot(aria-hidden='true')
                span= item.time
              h3.home-afisha_card-title!= item.title
              p.home-afisha_card-text= item.text
              .home-afisha_card-line
                span.home-afisha_card-line-label line up
                p.home-afisha_card-line-value= item.lineup
              a.home-afisha_card-more(href='/event.html')
                span Подробнее
                span.home-afisha_card-more-arrow(aria-hidden='true')

  section.home-club(aria-labelledby='home-club-title')
    .container.home-club_intro
      .home-club_content
        h2#home-club-title.title.title-h2.home-club_title Клуб
        p.home-club_text Клуб создан для тех, кто ценит приватность, атмосферу и уровень. Здесь проходят камерные вечера, живые выступления, интеллектуальные встречи и события, в которых важна не массовость, а качество аудитории и впечатления.
        p.home-club_text Пространство KAIFUSO продумано до мелочей: свет, звук, материалы и ритм зала создают ощущение уюта и одновременно статуса.
        p.home-club_text KAIFUSO — это клуб для тех, кто выбирает не место, а окружение. Пространство, где пересекаются идеи, люди и энергия нового времени.
        +Button('Подробнее', ['ghost-gold', 'md'])
      .home-club_media
        img(src='assets/img/kaifuso/main/club.jpg' alt='Клуб KAIFUSO')
    .container.home-club_form-wrap
      .home-club_form
        .home-club_form-head
          h2.title.title-h2.home-club_form-title Ваше мероприятие<br>в KAIFUSO
          p.home-club_form-subtitle Проведите ваше событие в атмосфере изысканной китайской кухни и безупречного сервиса
        .home-club_form-body
          +BookingForm({
            rootClass: 'contacts_form home-club-booking',
            title: '',
            fieldMode: 'contacts',
            privacyVariant: 'full',
            buttonText: 'Отправить заявку',
            buttonStyles: ['ghost-gold', 'lg']
          })

  section.home-gallery(aria-labelledby='home-gallery-title')
    h2#home-gallery-title.sr-only Галерея
    .home-gallery_slider
      each slide in gallerySlides
        a.home-gallery_slide(href=slide data-fancybox='home-gallery')
          img(src=slide alt='KAIFUSO gallery')
    .home-gallery_nav.swiper_nav
      button.swiper_nav_item.swiper_nav_item-prev.home-gallery_nav-prev(type='button' aria-label='Назад')
        span.gallery_nav_arrow.gallery_nav_arrow--left(aria-hidden='true')
      button.swiper_nav_item.swiper_nav_item-next.home-gallery_nav-next(type='button' aria-label='Вперед')
        span.gallery_nav_arrow.gallery_nav_arrow--right(aria-hidden='true')
    .home-gallery_pagination.swiper-pagination

  include ../components/sections/contacts-section.pug