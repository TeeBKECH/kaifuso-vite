//- @title: Царская палата - Индивидуальная баня
//- @description: Царская палата - Индивидуальная баня описание
//- @page_class: tsarpalata
extends ../layouts/default.pug

block content
  +IntroVideo({
    videoSrc: 'assets/video/video-bg.mp4',
    title: 'Царская палата',
    description: 'ваш личный княжеский сьют',
    breadcrumbs: ['Царская палата'],
    features: [
      {label: 'УЕДИНЕНИЕ', value: '2 атмосферных VIP-сьюта'},
      {label: 'ЭКСКЛЮЗИВНЫЕ ПАРНЫЕ', value: 'Уникальная глиняная, сеновал, 3D-хаммам'},
      {label: 'SPA-ЗОНА И ПРИВАТНЫЕ КУПЕЛИ, ТРАВЯНЫЕ ВАННЫ', value: 'Чередуй горячий пар и ледяную воду'}
    ],
    buttons: [
      {text: 'Забронировать царский сьют', styles: ['primary', 'lg']},
      {text: 'Смотреть программы', styles: ['secondary', 'lg']}
    ],
    showLogo: false
  })


  +PalacesSection({
    palaces: [
      {
        id: 'sila',
        title: 'ЦАРСКАЯ ПАЛАТА «СИЛА»',
        images: [
          'assets/img/ch-1.webp',
          'assets/img/ch-2.jpg',
          'assets/img/ch-3.jpg',
          'assets/img/ch-4.jpg'
        ],
        tabs: [
          {
            id: 'weekdays',
            label: 'ПН-ПТ',
            active: true,
            description: '2 VIP сьюта, SPA-зона, 3 авторских аромапара (в стоимость включено 6 входных билетов и 6 банных комплектов)',
            prices: [
              {value: '60 000 ₽', note: ['3 часа', '14 гостей']}
            ]
          },
          {
            id: 'weekend',
            label: 'СБ-ВС',
            active: false,
            description: '2 VIP сьюта, SPA-зона, 3 авторских аромапара (в стоимость включено 6 входных билетов и 6 банных комплектов)',
            prices: [
              {value: '80 000 ₽', note: ['3 часа', '14 гостей']}
            ]
          }
        ]
      },
      {
        id: 'dukh',
        title: 'ЦАРСКАЯ ПАЛАТА «ДУХ»',
        images: [
          'assets/img/ch-alt-1.webp',
          'assets/img/ch-alt-2.webp',
          'assets/img/ch-alt-3.jpg'
        ],
        tabs: [
          {
            id: 'weekdays',
            label: 'ПН-ПТ',
            active: true,
            description: 'SPA-зона, 3 авторских аромапара (входные билеты оплачиваются отдельно)',
            prices: [
              {value: '15 000 ₽', note: '3 часа'},
              {value: '120 ₽', note: '1 мин'}
            ]
          },
          {
            id: 'weekend',
            label: 'СБ-ВС',
            active: false,
            description: 'SPA-зона, 3 авторских аромапара (входные билеты оплачиваются отдельно)',
            prices: [
              {value: '18 000 ₽', note: '3 часа'},
              {value: '170 ₽', note: '1 мин'}
            ]
          }
        ]
      }
    ]
  })

  +RitualsSection({
    title: 'Банные обряды',
    cardMixin: 'RitualCard',
    items: [
      {
        title: 'Банный обряд «Княже»',
        img: 'assets/img/banya-3.webp',
        items: [
          'Приветственный аромапар',
          'Индивидуальное парение',
          'Контраст на ваш выбор',
          'Второй заход на парение',
          'Скраб на выбор гостя',
          'Мыльная помывка в хаммаме',
          'Завершающий аромапар',
          'Звукотерапия в сенной комнате',
          'Чаепитие'
        ],
        price: '35 000₽',
        note: '1 гость / 3 часа'
      },
      {
        title: 'Банный обряд «Богатырь»',
        description: 'Программа для «сталеваров», любителей крепкого пара:',
        img: 'assets/img/banya-5.webp',
        items: [
          'Приветственный аромапар',
          'Первый заход парение в 4 руки',
          'Контраст на ваш выбор',
          'Второй заход парение в 4 руки',
          'Третий заход парение в 2 руки',
          'Контраст на ваш выбор',
          'Четвертый заход парение в 2 руки',
          'Завершающий аромапар',
          'Звукотерапия в сенной комнате',
          'Чаепитие',
        ],
        price: '40 000₽',
        note: '1 гость / 3 часа'
      },
      {
        title: 'Банный обряд «Царское СПА»',
        description: 'Программа для любителей комплексного СПА:',
        img: 'assets/img/spa-1.webp',
        items: [
          'Приветственный аромапар',
          'Скрабирование на ваш выбор',
          'Мыльная помывка в хаммаме',
          'Индивидуальное парение',
          'Общий массаж на 40 минут',
          'Увлажнение тела',
          'Звукотерапия в сенной комнате',
          'Чаепитие',
        ],
        price: '35 000₽',
        note: '1 гость / 3 часа'
      },
    ]
  })

  include ../components/sections/cta.pug

  include ../components/sections/benefits.pug

  +Spa({
    title: 'СПА ПРОГРАММЫ',
    items: [
      {
        title: 'Княжеский отдых',
        duration: '1,5 часа',
        img: 'assets/img/spa-1.webp',
        items: [
          'Арома-скраб на выбор (смородина, ананас, манго)',
          'Массаж 40 минут',
          'Увлажнение тела',
          'Отдых на сеновале',
          'Чайная церемония на сеновале'
        ],
        price: '9 000 ₽',
        guests: '1 ГОСТЬ',
        price2: '16 000 ₽',
        guests2: '2 ГОСТЯ'
      },
      {
        title: 'ЦАРСКОЕ РАССЛАБЛЕНИЕ',
        duration: '1,5 часа',
        img: 'assets/img/spa-2.webp',
        items: [
          'Обертывание на выбор (шоколад, ламинария)',
          'Массаж 40 минут',
          'Увлажнение тела',
          'Отдых на сеновале',
          'Чайная церемония с угощениями'
        ],
        price: '10 000 ₽',
        guests: '1 ГОСТЬ',
        price2: '18 000₽',
        guests2: '2 ГОСТЯ'
      },
      {
        title: 'КОРОЛЕВСКОЕ УДОВОЛЬСТВИЕ',
        duration: '2 часа',
        img: 'assets/img/spa-3.webp',
        description: 'Программа для любителей комплексного СПА:',
        items: [
          'Арома-скраб на выбор (смородина, ананас, манго)',
          'Обертывание на выбор (шоколад, ламинария)',
          'Массаж 40 минут',
          'Увлажнение тела',
          'Отдых на сеновале',
          'Чайная церемония на сеновале'
        ],
        price: '15 000₽',
        guests: '1 ГОСТЬ',
        price2: '28 000 ₽',
        guests2: '2 ГОСТЯ'
      }
    ]
  })

  section.section.section--prices(data-aos="fade-up", data-aos-duration="1000")
    .container.section_container
      .prices
        +PriceAltCategory('Цены на услуги')
          +PriceAltSubsection('Банные обряды', true)
            +PriceAltTable({
              headers: ['Услуга', 'Цена', 'Условия'],
              rows: [
                { cells: ['Банный обряд «Князь Владимир»', '70 000 ₽', '1 человек'] },
                { cells: ['Банный обряд «КНЯЖЕ»', '35 000 ₽', '3 часа'] },
                { cells: ['Банный обряд «БОГАТЫРЬ»', '40 000 ₽', '3 часа'] },
                { cells: ['Банный обряд «ЦАРСКОЕ СПА»', '35 000 ₽', '3 часа'] }
              ]
            })

          +PriceAltSubsection('СПА программы', true)
            +PriceAltTable({
              headers: ['Услуга', '1 гость', '2 гостя'],
              rows: [
                { cells: ['СПА ПРОГРАММА «КНЯЖЕСКИЙ ОТДЫХ»', '9 000 ₽', '16 000 ₽'] },
                { cells: ['СПА ПРОГРАММА «ЦАРСКОЕ РАССЛАБЛЕНИЕ»', '10 000 ₽', '18 000 ₽'] },
                { cells: ['СПА ПРОГРАММА «КОРОЛЕВСКОЕ УДОВОЛЬСТВИЕ»', '15 000 ₽', '28 000 ₽'] }
              ]
            })

          +PriceAltSubsection('СЬЮТЫ', true)
            +PriceAltTable({
              headers: ['Услуга', 'Цена'],
              rows: [
                { cells: ['Царская палата (3 ч, до 14 гостей)', '60 000 ₽'] },
                { cells: ['VIP сьют (по минутам)', '120 ₽/мин'] }
              ]
            })
