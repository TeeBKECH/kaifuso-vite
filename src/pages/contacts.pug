//- @title: Контакты
//- @description: Контакты банного комплекса «Княже» - адрес, телефон, форма обратной связи
//- @page_class: contacts
//- @has_intro: false
extends ../layouts/default.pug

block content
  section.contacts(aria-labelledby='contacts-title')
    .contacts_bg(aria-hidden='true')
    +PageHero({
      title: 'Контакты',
      breadcrumbs: ['Контакты'],
      rootClass: 'contacts_hero',
      titleId: 'contacts-title'
    })
    .contacts_body
      .container.contacts_body_container
        .contacts_info
          .contacts_info-main
            .contacts_info-address
              h2.contacts_info-title ул. Кузнецкий мост, д.6/3
              a.contacts_info-route(
                href='https://yandex.ru/maps/?text=%D0%9A%D1%83%D0%B7%D0%BD%D0%B5%D1%86%D0%BA%D0%B8%D0%B9%20%D0%BC%D0%BE%D1%81%D1%82%2C%206%2F3'
                target='_blank'
                rel='noopener noreferrer nofollow'
              )
                span.contacts_info-route-text Построить маршрут
                span.icon-external(aria-hidden='true')
                  img(src='assets/img/kaifuso/icon-arrow-external.svg' alt='' decoding='async')
            .contacts_info-contact
              a.contacts_info-phone(href='tel:+74957302277') 7 (495) 730 22 77
              a.contacts_info-mail(href='mailto:info@kaifuso.rest') info@kaifuso.rest
          .contacts_info-socials
            a.contacts_info-social(href='#' target='_blank' rel='noopener noreferrer nofollow' aria-label='Telegram')
              img(src='assets/img/kaifuso/icon-tg.svg' alt='')
            a.contacts_info-social(href='#' target='_blank' rel='noopener noreferrer nofollow' aria-label='ВКонтакте')
              img(src='assets/img/kaifuso/icon-vk.svg' alt='')
            a.contacts_info-social(href='#' target='_blank' rel='noopener noreferrer nofollow' aria-label='YouTube')
              img(src='assets/img/kaifuso/icon-youtube.svg' alt='')
        .contacts_form
          h2.contacts_form-title Забронировать стол
          form.contacts_form-body(action='#')
            .contacts_form-grid
              .contacts_form-field
                input.contacts_form-input(type='text' name='name' placeholder='Ваше имя')
              .contacts_form-field
                input.contacts_form-input.form_input-tel(type='tel' name='tel' placeholder='+7 (___) ___-__-__')
              .contacts_form-field.contacts_form-field--icon
                input.contacts_form-input(type='text' name='datetime' placeholder='Дата и время')
                span.contacts_form-field-icon(aria-hidden='true')
                  span.contacts_form-field-glyph.contacts_form-field-glyph--calendar
              .contacts_form-field.contacts_form-field--icon
                input.contacts_form-input(type='text' name='persons' placeholder='Количество персон')
                span.contacts_form-field-icon(aria-hidden='true')
                  span.contacts_form-field-glyph.contacts_form-field-glyph--down
            .contacts_form-field.contacts_form-field--textarea
              textarea.contacts_form-input.contacts_form-textarea(name='message' placeholder='Добавить комментарий')
            .contacts_form-footer
              label.contacts_form-privacy
                span.contacts_form-privacy-check
                  span.contacts_form-privacy-glyph(aria-hidden='true')
                span.contacts_form-privacy-text
                  | Я ознакомлен и согласен
                  br
                  | с 
                  a(href='privacy.html') политикой обработки персональных данных
              +Button('Забронировать стол', ['ghost-gold', 'lg'], 'submit')(class='contacts_form-submit')