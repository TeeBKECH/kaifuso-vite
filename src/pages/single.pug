//- @title: Кухня как театр: от сезонного меню до подачи
//- @description: Материалы блога KAIFUSO — кухня, сервис, события
//- @page_class: single
//- @has_intro: false
extends ../layouts/default.pug

block content
  -
    const img = (n) => {
      const pool = [
        'assets/img/kaifuso/about/interior.jpg',
        'assets/img/kaifuso/about/kitchen.jpg',
        'assets/img/kaifuso/about/club.jpg',
        'assets/img/kaifuso/main/club.jpg',
        'assets/img/kaifuso/main/about-left.png',
        'assets/img/kaifuso/main/about-right-bird.png',
      ]
      return pool[n % pool.length]
    }
    const relatedPosts = [
      { href: 'single.html', title: 'Винная карта: с чего начать', excerpt: 'Пара сочетаний с кантонскими блюдами — коротко и по делу.', image: img(1), date: '3 мая 2026', readTime: '8 мин' },
      { href: 'single.html', title: 'Интерьер и свет в зале', excerpt: 'Как ритм освещения поддерживает настроение вечера.', image: img(2), date: '28 апреля 2026', readTime: '5 мин' },
      { href: 'single.html', title: 'Клуб KAIFUSO: форматы вечеров', excerpt: 'Камерные встречи и приватность — что важно знать гостю.', image: img(3), date: '19 апреля 2026', readTime: '7 мин' },
      { href: 'single.html', title: 'Чайная церемония и десерты', excerpt: 'Пара чаёв к финальной тарелке ужина.', image: img(4), date: '8 апреля 2026', readTime: '4 мин' },
      { href: 'single.html', title: 'Сезонность на тарелке', excerpt: 'Откуда продукты и почему меню меняется.', image: img(5), date: '1 апреля 2026', readTime: '9 мин' },
      { href: 'single.html', title: 'Бар: сигнатуры и классика', excerpt: 'Коктейли с азиатскими нотами к вашему столу.', image: img(0), date: '22 марта 2026', readTime: '6 мин' },
    ]
  +PageHero({
    title: 'Кухня как театр: от сезонного меню до подачи',
    breadcrumbs: ['Блог', 'Кухня как театр'],
    rootClass: 'single-page_hero',
    titleId: 'single-hero-title'
  })

  section.section.section--single
    .container.single_container
      .single_content
        article.single_article
          figure.single_lead
            img(src='assets/img/kaifuso/about/kitchen.jpg' alt='Кухня KAIFUSO' width='1200' height='675' loading='eager' decoding='async')

          .single_prose.entry-content
            p.single_lead-text
              | Этот материал сверстан так, как обычно выходит запись Gutenberg в WordPress:
              |  заголовки разных уровней, ссылки, акценты, списки, цитаты, код, таблицы и медиа.
              |  В шаблоне темы достаточно вывести
              code  the_content()
              |  внутри контейнера
              code  entry-content
              | , и стили подхватятся автоматически.

            h2 Вступление и смысл блока
            p
              | Подачу блюда мы рассматриваем как часть спектакля: ритм света,
              |  тишина между столами, точность официанта, темп кухни.
              |  Ниже — структурированный текст, удобный для проверки типографики
              |  и работы оглавления.
            p
              | Каждый абзац держит ровный вертикальный ритм. Обратите внимание:
              strong  акценты
              | ,
              em  интонация
              |  и
              a(href='blog.html') гиперссылки
              |  выглядят сбалансированно и не ломают сетку.

            h3 Подзаголовок уровня H3
            p
              | Заголовки H2 и H3 формируют иерархию контента и попадают
              |  в оглавление справа (см. виджет «Содержание»).

            h4 Подзаголовок уровня H4
            p
              | Заголовки H4 — для глубоких подразделов: цвет приглушён,
              |  верхний регистр и градиент золотого тут не используются.

            h3 Маркированный список
            ul
              li Сезонное меню обновляется каждые 6–8 недель.
              li Команда зала знает состав сетов и подскажет пару к вину.
              li Для аллергий и ограничений оставьте пометку при бронировании заранее.
              li Большие компании и приватные ужины — по запросу через форму на сайте.

            h3 Нумерованный список
            ol
              li Выберите дату и время визита.
              li Согласуйте формат: à la carte, дегустация или закрытый сет.
              li Получите подтверждение и напоминание по SMS за день до визита.
              li Если планы меняются — мы переносим бронь без вопросов.

            blockquote.single_blockquote
              p
                | «Гость не обязан замечать сервис —
                |  он обязан чувствовать заботу».

            h2 Код и технические детали
            p
              | Иногда внутри статьи появляются сниппеты — например, как
              |  подключить ленту похожих записей через хук WordPress:
            pre.single_pre: code.single_code.
              // Пример: хук после контента
              add_action('wp_footer', function () {
                if (is_single()) {
                  echo '&lt;script&gt;initRelatedPostsSwiper()&lt;/script&gt;';
                }
              });

            h2 Таблица
            p Простая двухколоночная таблица с подсветкой шапки:
            .single_table-wrap
              table.single_table
                thead
                  tr
                    th Этап
                    th Описание
                tbody
                  tr
                    td Подготовка
                    td Мизанплас, температура тарелок, финальная сборка.
                  tr
                    td Подача
                    td Краткое представление блюда без лекции за столом.
                  tr
                    td Финал
                    td Десерт, чай или дижестив — на выбор гостя.

            figure.single_figure
              img(src='assets/img/kaifuso/about/interior.jpg' alt='Интерьер зала' loading='lazy' decoding='async')
              figcaption Интерьер главного зала — тёплые тона и приглушённый свет.

            h2 Заключение
            p
              | Если нужен другой набор блоков Gutenberg — заголовки внутри
              code  .single_prose
              |  автоматически попадут в оглавление справа.
              |  В скрипте оглавления можно расширить набор уровней
              |  (по умолчанию H2 и H3) и поменять
              a(href='#') правила сборки
              | .

      aside.single_sidebar
        .widget
          .widget-title Содержание
          ul#toc-list.toc-list

  section.blog-related(aria-labelledby='blog-related-title')
    .container.blog-related_container
      .blog-related_head
        h2#blog-related-title.blog-related_title Ещё записи
        .swiper_nav.blog-related_nav
          button.swiper_nav_item.blog-related_nav-prev(type='button' aria-label='Назад')
            span.gallery_nav_arrow.gallery_nav_arrow--left(aria-hidden='true')
          button.swiper_nav_item.blog-related_nav-next(type='button' aria-label='Вперед')
            span.gallery_nav_arrow.gallery_nav_arrow--right(aria-hidden='true')
      .blog-related_items
        each post in relatedPosts
          .blog-related_slide
            +BlogPostCard(post)
