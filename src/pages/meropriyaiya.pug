//- @title: Ваши мероприятия в центре Москвы под ключ
//- @description: Закрытие банного комплекса «Княже» под мероприятия: сценарии, зоны, поэтажный план и аренда на 30–60 гостей.
//- @page_class: meropriyaiya
extends ../layouts/default.pug

//- Сетка сценариев: при переносе в WP выводите те же классы/атрибуты из админки.
//-   — class: meropriyaiya_scenarios meropriyaiya_scenarios--count-{N} (раскладки N=4,7,8 — в meropriyaiya.scss)
//-   — data-scenarios-count="{N}" (число карточек) — для стилей/JS без пересборки
//- Раскладка/фон карточек: N===4 → 2×2 + порядок cream/gold/gold/cream по слотам; N===5 → последняя карточка всегда gold; иначе — поле variant из данных.
mixin meropriyaiyaScenariosGrid(cards)
  - const scenarioN = cards.length
  - const scenariosClasses = ['meropriyaiya_scenarios', `meropriyaiya_scenarios--count-${scenarioN}`]
  .meropriyaiya_scenarios(class=scenariosClasses.join(' '), data-scenarios-count=scenarioN)
    each card, index in cards
      -
        let scenarioVariant = card.variant
        if (scenarioN === 5 && index === scenarioN - 1) scenarioVariant = 'gold'
        if (scenarioN === 4) {
          const meropriyaiyaScenarioFourTone = ['cream', 'gold', 'gold', 'cream']
          scenarioVariant = meropriyaiyaScenarioFourTone[index] || card.variant
        }
      article.meropriyaiya_scenario(class=`meropriyaiya_scenario--${scenarioVariant}`)
        +ScenarioFrame()
          .meropriyaiya_scenario-head
            span.meropriyaiya_scenario-roman= card.roman
            h3.meropriyaiya_scenario-title= card.title
          .meropriyaiya_scenario-cols
            each col in card.cols
              ul.meropriyaiya_scenario-list
                each line in col
                  li.meropriyaiya_scenario-li= line

block content
  -
    const meropriyaiyaScenarioCards = [
      { variant: 'cream', roman: 'I', title: 'Частные мероприятия', cols: [['День рождения', 'Юбилей', 'Девичник'], ['Мальчишник', 'Семейный праздник', 'Свидание']] },
      { variant: 'gold', roman: 'II', title: 'Бизнес-мероприятия', cols: [['Корпоратив', 'Тимбилдинг', 'Переговоры'], ['Презентация', 'Нетворкинг', 'Бизнес-баня']] },
      { variant: 'cream', roman: 'III', title: 'Торжественные события', cols: [['Свадьба', 'Гендер-пати'], ['Банкет', 'Фуршет']] },
      { variant: 'gold', roman: 'IV', title: 'Отдых и восстановление', cols: [['Антистресс программа', 'Релакс программы'], ['СПА-день', 'Wellness в бане']] },
      { variant: 'cream', roman: 'V', title: 'Вечеринки и отдых', cols: [['Вечеринка', 'Тематическая вечеринка'], ['Afterparty', 'Встреча друзей']] },
      { variant: 'gold', roman: 'VI', title: 'Специальные форматы', cols: [['Фотосессия', 'Съёмки'], ['Мастер-класс']] },
    ]
    const meropriyaiyaFig = 'assets/img/meropriyaiya/figma'
    const meropriyaiyaWhyCards = [
      { img: `${meropriyaiyaFig}/why-01.png`, text: 'Пар, что лечит, а не обжигает — плавный прогрев от 60 °C, идеально и для бывалых, и для новичков' },
      { img: `${meropriyaiyaFig}/why-02.png`, text: 'Аромапары по расписанию — мята, смородина, пихта… каждые 60 минут новый ритуал' },
      { img: `${meropriyaiyaFig}/why-03.png`, text: 'Иммерсивная атмосфера «обряд в древней Руси»' },
      { img: `${meropriyaiyaFig}/why-04.jpg`, text: 'Локация рядом с Москва-Сити (деловой центр)' },
    ]
    const meropriyaiyaZones = [
      { roman: 'I', title: 'просторная трапезная', note: 'до 60 гостей', img: `${meropriyaiyaFig}/zone-i-trapeznaya.png`, tall: true },
      { roman: 'II', title: '2 атмосферных VIP-сьюта', note: 'до 8 гостей', img: `${meropriyaiyaFig}/zone-ii-vip.jpg`, tall: true },
      { roman: 'III', title: 'гранд купель — самая большая в Москве', note: 'до 60 гостей', img: `${meropriyaiyaFig}/zone-iii-grand-kupel.png`, tall: true },
      { roman: 'IV', title: '3D хаммам', note: 'до 15 гостей', img: `${meropriyaiyaFig}/zone-iv-hammam.png`, tall: false },
      { roman: 'V', title: 'купель', note: '', img: `${meropriyaiyaFig}/zone-v-kupel.png`, tall: false },
      { roman: 'VI', title: 'сеновал', note: 'до 10 гостей', img: `${meropriyaiyaFig}/zone-vi-senoval.png`, tall: false },
      { roman: 'VII', title: 'Царская палата «Сила»', note: 'до 8 гостей', img: `${meropriyaiyaFig}/zone-ii-vip.jpg`, tall: false },
      { roman: 'VIII', title: 'Царская палата «Дух»', note: 'до 6 гостей', img: `${meropriyaiyaFig}/zone-viii-duh.jpg`, tall: false },
      { roman: 'IX', title: 'комната диковин', note: 'до 2 гостей', img: `${meropriyaiyaFig}/zone-ix-dikovin.jpg`, tall: false },
    ]
    const meropriyaiyaRentalLines = [
      'Приветственная встреча по русским традициям',
      'Аромапарения каждый час',
      'Интерактивы с актёрами',
      'Банкетное меню (по запросу)',
      'Банный текстиль для каждого гостя',
      'Чайный стол (травяной чай, сушки, мёд)',
      'Сенной зал',
    ]
    const meropriyaiyaGalleryVisible = [
      { src: `${meropriyaiyaFig}/gallery-01.jpg`, caption: 'Мероприятие в «Княже»' },
      { src: `${meropriyaiyaFig}/gallery-02.jpg`, caption: 'Гости в бане' },
      { src: `${meropriyaiyaFig}/gallery-03.jpg`, caption: 'Кейтеринг' },
      { src: `${meropriyaiyaFig}/gallery-04.jpg`, caption: 'Застолье в комплексе' },
    ]
    const meropriyaiyaGalleryExtra = [
      { src: `${meropriyaiyaFig}/why-01.png`, caption: 'Атмосфера комплекса' },
      { src: `${meropriyaiyaFig}/why-02.png`, caption: 'Банный ритуал' },
      { src: `${meropriyaiyaFig}/rental-primary.png`, caption: 'Трапезная для гостей' },
    ]

  +IntroVideo({
    videoSrc: 'assets/video/video-bg.mp4',
    videoAttrs: { poster: 'assets/img/meropriyaiya/figma/hero-poster.png' },
    title: 'ВАШИ мероприятия<br />в центре Москвы ПОД КЛЮЧ',
    breadcrumbs: ['Мероприятия под ключ'],
    featuresV2: [
      {label: 'I', value: 'Настоящий отдых'},
      {label: 'II', value: 'Живые эмоции'},
      {label: 'III', value: 'Безупречный сервис'},
    ],
    buttons: [
      {text: 'Провести мероприятие', styles: ['secondary', 'lg']},
    ],
    showLogo: false
  })

  section.section.section--meropriyaiya-gallery(data-aos="fade-up", data-aos-duration="800")
    .container.section_container
      +SectionTitle({
        title: 'Настоящий иммерсив для вашего события',
        size: 'lg',
        type: 'gold',
        center: true
      })
      .meropriyaiya_gallery
        each item in meropriyaiyaGalleryVisible
          a.meropriyaiya_gallery-cell(
            href=item.src,
            data-fancybox='meropriyaiya-gallery',
            data-caption=item.caption,
            aria-label=`Открыть фото: ${item.caption}`
          )
            img.meropriyaiya_gallery-img(src=item.src, alt=item.caption, loading='lazy')
        .meropriyaiya_gallery-skip(aria-hidden='true')
          each item in meropriyaiyaGalleryExtra
            a(href=item.src, data-fancybox='meropriyaiya-gallery', data-caption=item.caption, tabindex='-1')

  section.section.section--meropriyaiya-scenarios(data-aos="fade-up", data-aos-duration="800")
    .features_bg(aria-hidden="true")
      .features_bg_dust.features_bg_dust--1
      .features_bg_dust.features_bg_dust--2
      .features_bg_dust.features_bg_dust--3
      .features_bg_dust.features_bg_dust--4
      .features_bg_dust.features_bg_dust--5
      .features_bg_dust.features_bg_dust--6
      .features_bg_dust.features_bg_dust--7
      .features_bg_dust.features_bg_dust--8
      .features_bg_overlay
    .container.section_container
      +SectionTitle({
        title: 'Сценарии и форматы мероприятий в бане',
        subtitle: 'От отдыха с друзьями до деловых встреч и торжеств организуем любой формат с комфортом, приватностью и высоким уровнем сервиса.',
        size: 'lg',
        type: 'gold',
        center: true
      })
      +meropriyaiyaScenariosGrid(meropriyaiyaScenarioCards)

  include ../components/sections/cta.pug

  section.section.section--meropriyaiya-why(data-aos="fade-up", data-aos-duration="800")
    .container.section_container
      +SectionTitle({
        title: 'Почему выбирают «Княже»',
        size: 'lg',
        type: 'gold',
        center: true
      })
      .meropriyaiya_why
        each item in meropriyaiyaWhyCards
          .meropriyaiya_why-card
            .meropriyaiya_why-media
              img.meropriyaiya_why-img(src=item.img, alt='', loading='lazy')
            p.meropriyaiya_why-text= item.text

  section.section.section--meropriyaiya-spaces(data-aos="fade-up", data-aos-duration="800")
    .container.section_container
      +SectionTitle({
        title: 'Пространства и зоны комплекса',
        size: 'lg',
        type: 'gold',
        center: true
      })
      .meropriyaiya_spaces
        each zone in meropriyaiyaZones
          article.meropriyaiya_space(class=zone.tall ? 'meropriyaiya_space--tall' : '')
            .meropriyaiya_space-media
              img.meropriyaiya_space-img(src=zone.img, alt=zone.title, loading='lazy')
            .meropriyaiya_space-meta
              span.meropriyaiya_space-roman= zone.roman
              h3.meropriyaiya_space-title= zone.title
            if zone.note
              p.meropriyaiya_space-note= zone.note

  //- Табы: отдельная вёрстка под макет (подписи этажей + линия активного), логика та же, что у +Tabs (initTabsAll)
  section.section.section--meropriyaiya-floor(data-aos="fade-up", data-aos-duration="800")
    .container.section_container
      +SectionTitle({
        title: 'Поэтажный план',
        size: 'lg',
        type: 'gold',
        center: true
      })
      .meropriyaiya_floor-tabs.tabs(data-component='tabs')
        .meropriyaiya_floor-tab-buttons.tabs_buttons
          +Button('1 этаж', ['secondary', 'md'])(data-tab-button, data-tab-index=0, data-tab-active=true, data-tab-variant='secondary', data-tab-inactive-variant='primary')
          +Button('2 этаж', ['primary', 'md'])(data-tab-button, data-tab-index=1, data-tab-active=false, data-tab-variant='primary', data-tab-inactive-variant='primary')
          +Button('3 этаж', ['primary', 'md'])(data-tab-button, data-tab-index=2, data-tab-active=false, data-tab-variant='primary', data-tab-inactive-variant='primary')
          +Button('3D-тур', ['primary', 'md'])(data-tab-button, data-tab-index=3, data-tab-active=false, data-tab-variant='primary', data-tab-inactive-variant='primary')
        .tabs_content
          .tabs_item.tabs_item--active(data-tab-content=0, data-tab-active=true)
            .meropriyaiya_floor-plan-img
              img(src=`${meropriyaiyaFig}/floor-plan.png`, alt='План первого этажа', loading='lazy')
              p.meropriyaiya_floor-plan-note Схема из макета ориентировочная — уточняйте площади и планировку у администратора. Отдельные файлы по этажам подставьте при финальной выгрузке.
          .tabs_item(data-tab-content=1, data-tab-active=false)
            .meropriyaiya_floor-plan-img
              img(src=`${meropriyaiyaFig}/floor-plan.png`, alt='План второго этажа', loading='lazy')
              p.meropriyaiya_floor-plan-note Пока используется тот же план, что на первом табе — замените выгрузкой по этажам из Figma.
          .tabs_item(data-tab-content=2, data-tab-active=false)
            .meropriyaiya_floor-plan-img
              img(src=`${meropriyaiyaFig}/floor-plan.png`, alt='План третьего этажа', loading='lazy')
              p.meropriyaiya_floor-plan-note Пока используется тот же план — замените выгрузкой по этажам из Figma.
          .tabs_item(data-tab-content=3, data-tab-active=false)
            .meropriyaiya_floor-plan-img
              img(src=`${meropriyaiyaFig}/tour-3d.png`, alt='3D-тур по комплексу', loading='lazy')
              p.meropriyaiya_floor-plan-note При интеграции: панорама или внешняя ссылка на 3D-тур.

  section.section.section--meropriyaiya-rental(data-aos="fade-up", data-aos-duration="800")
    .container.section_container
      .meropriyaiya_rental
        .meropriyaiya_rental-main
          h2.meropriyaiya_rental-title.title.title-h2 Аренда комплекса<br />на 30–60 гостей
          p.meropriyaiya_rental-lead Закрытие комплекса
          ul.meropriyaiya_rental-list
            each line in meropriyaiyaRentalLines
              li.meropriyaiya_rental-li= line
          a.meropriyaiya_rental-link(href='contacts.html') индивидуальный расчёт
        .meropriyaiya_rental-visual
          .meropriyaiya_rental-visual-hero
            img.meropriyaiya_rental-img(src=`${meropriyaiyaFig}/rental-primary.png`, alt='Гости за трапезной в «Княже»', loading='lazy')
          .meropriyaiya_rental-visual-pair
            img.meropriyaiya_rental-img(src=`${meropriyaiyaFig}/rental-stack-01.png`, alt='Встреча гостей', loading='lazy')
            img.meropriyaiya_rental-img(src=`${meropriyaiyaFig}/rental-stack-02.png`, alt='Отдых в бане', loading='lazy')

  section.section.section--seo-text
    .container.section_container
      .seo_text-wrapper
        .seo_text.seo_text--trunc
          h2.title.title-h2 Сео Текст
          p Кедровая парная — сердце нашей общей бани. Отделка из сибирского кедра создаёт неповторимый аромат и мягкий, целебный пар. Здесь комфортно и большой компании друзей, и тем, кто любит спокойную атмосферу.
          p Высокие полки, удобные лежаки и продуманная вентиляция позволяют каждому найти свой угол. После парной — купель с прохладной водой и зона отдыха с чаем и мёдом.
          p Далеко-далеко 
