include ../components/mixins/theme-switcher.pug


doctype html
// page — объект из templateParameters; theme_default, theme_switcher, has_intro — для WP/ACF
- const hasIntro = page.has_intro !== false && String(page.has_intro || '').toLowerCase() !== 'false'
html(
  lang="ru"
  data-theme-default=(page.theme_default || 'light')
  data-theme-switcher=(page.theme_switcher !== false ? 'true' : 'false')
  data-has-intro=(hasIntro ? 'true' : 'false')
)
  +Head(page)

  body.body

    // Modal Form
    +Modal('modal-form')(class='modal--form modal--booking')
      .modal_cls(data-close='')
      +FormModal()
    
    // Modal pop up (data-popup-delay, data-popup-on-leave для теста в верстке)
    +Modal('modal-popup')(class='modal--popup modal--booking-success' data-popup-delay='0' data-popup-on-leave='false')
      .modal_cls(data-close='')
      +FormModalSuccess()

    // Меню в модалке: десктоп (бургер site) — основная навигация; мобильный — полноэкранное меню
    +Modal('site-menu')(class='modal--site-nav')
      .modal_cls(data-close='')
      +NavMain()(class='nav--site-modal')
    
    +Modal('mobile-menu')(class='modal--mobile')
      +NavMobile()
    
    // Modal Video Player (для страницы комнаты и карточек с видео)
    +ModalVideoPlayer()

    // Bottom Nav
    +NavBottom({items: [
      {icon: 'tg', text: 'Telegram'},
      {icon: 'max', text: 'MAX'},
      {icon: 'vk', text: 'Vkonakte'},
      {icon: 'tel', text: 'Позвонить'},
    ]})

    // Scroll to top (миксин Button с иконкой, вид как у кнопки навигации свайпера)
    +Button('Наверх', ['primary'], { icon: 'assets/img/kaifuso/icon-arrow-up.svg', iconOnly: true })(class='scroll-to-top' type='button' aria-label='Наверх')

    .page(class=`${page.page_class ? 'page--' + page.page_class : ''}`)
      include ../components/sections/header.pug
      main.main(class=`${page.page_class ? 'main--' + page.page_class : ''}`)
        block content
      include ../components/sections/footer.pug