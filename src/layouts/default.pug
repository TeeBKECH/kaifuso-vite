include ../components/mixins/logo.pug
include ../components/mixins/burger.pug
include ../components/mixins/socials.pug
include ../components/mixins/modal.pug
include ../components/mixins/intro.pug
include ../components/mixins/section.pug
include ../components/mixins/card.pug
include ../components/mixins/gallery.pug
include ../components/mixins/events.pug
include ../components/mixins/breadcrumbs.pug
include ../components/mixins/seo.pug
include ../components/mixins/pagination.pug
include ../components/mixins/accordion.pug
include ../components/mixins/link.pug
include ../components/mixins/select.pug
