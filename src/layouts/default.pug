doctype html
// page — объект из templateParameters; theme_default, theme_switcher, has_intro — для WP/ACF
- const hasIntro = page.has_intro !== false && String(page.has_intro || '').toLowerCase() !== 'false'
html(
  lang="ru"
  data-theme-default=(page.theme_default || 'light')
  data-theme-switcher=(page.theme_switcher !== false ? 'true' : 'false')
  data-has-intro=(hasIntro ? 'true' : 'false')
)
  +Head(page)

  body.body

    // Modal Form
    +Modal('modal-form')(class='modal--form')
      .modal_cls(data-close='')
      +FormModal()
    
    // Modal pop up (data-popup-delay, data-popup-on-leave для теста в верстке)
    +Modal('modal-popup')(class='modal--popup' data-popup-delay='3' data-popup-on-leave='false')
      .modal_cls(data-close='')
      .popup_content
        h3.popup_title Билет на 3 часа в Мовню — 2900₽
        .popup_text
          p Понедельник-четверг с 10:00 до 13:00
          p.notice Акция не суммируется с другими акциями и предложениями
        +Button('Подробнее', ['secondary', 'lg', 'fw'])(data-modal='modal-form' data-modal-action='open')

