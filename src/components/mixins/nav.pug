mixin MenuItem(props = {})
  li.menu_item&attributes(attributes)
    if (props.href)
      a.menu_item_link(href=props.href)= props.link
    else
      span.menu_item_link= props.link
    if (props.submenu && props.submenu.length > 0)
        span.menu_item_icon
    if (props.submenu && props.submenu.length > 0)
      ul.menu-drop
        each subItem in props.submenu
          li.menu-drop__item
            a.menu-drop__link(href=subItem.href)= subItem.link

mixin MenuItemMobile(props = {}, index = 0)
  - const {link = '', href = '', submenu = []} = props || {}
  - const hasDrop = submenu && submenu.length > 0
  - const dropId = hasDrop ? `menu-drop-${index}` : ''
  li.menu_item(class=hasDrop ? 'menu_item--has-drop' : '')&attributes(attributes)
    if (href)
      a.menu_item_link(href=href)= link
    else
      span.menu_item_link= link
    if (hasDrop)
      ul.menu-drop(id=dropId role="list")
        each subItem in props.submenu
          li.menu-drop__item
            a.menu-drop__link(href=subItem.href)= subItem.link
    if (hasDrop)
      button.menu_item_icon(type="button" aria-expanded="false" aria-controls=dropId data-menu-drop-toggle aria-label="Открыть подменю")

mixin NavMain(props = {})
  - const { items = kaifusoNav } = props
  nav.nav&attributes(attributes)
    ul.menu
      each item, index in items
        +MenuItem(item)

