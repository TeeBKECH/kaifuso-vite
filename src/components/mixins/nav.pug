mixin NavBottom(props = {})
  - const {items = []} = props
  nav.bottom-nav&attributes(attributes)
    each item, index in items
      +BottomNavItem(item)

mixin BottomNavItem(props = {})
  - const {icon = '', text = ''} = props
  a.bottom-nav_item(href=props.href)
    .bottom-nav_item-icon
      img(src=`assets/img/${icon}.svg`, alt=`${text} Icon`)
    span.bottom-nav_item-label= props.text
