mixin Head(props)
  head
    script.
      (function(){var d=document.documentElement;var def=(d.getAttribute('data-theme-default')||'light').toLowerCase();var themes=['light','dark'];var stored;try{stored=localStorage.getItem('knyaje-theme');}catch(e){stored=null;}d.dataset.theme=(stored&&themes.indexOf(stored)>=0)?stored:def;})();
    link(rel="icon", href='assets/img/new/logo-main.svg', sizes="32x32")
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    if props && props.description
      meta(name="description" content=props.description)
    title #{(props && props.title) ? props.title : 'Мой проект'}