//- Опции для кнопки: { type?, icon?, iconAlt?, iconOnly?, arrow? }
//- icon  — путь к svg/img-иконке
//- iconOnly — только иконка, текст скрыт визуально (для a11y остаётся)
//- arrow — CSS-стрелка справа: 'right' | 'left' | 'up' | 'down'
mixin Button(text = 'Текст кнопки', styles = ['primary'], typeOrOptions = 'button')
  - let classes = ''
  - const defaultSize = 'md'
  - let hasSize = false
  - let hasVariant = false
  - const opts = typeof typeOrOptions === 'object' ? typeOrOptions : { type: typeOrOptions }
  - const { type = 'button', icon = '', iconAlt = '', iconOnly = false, arrow = '' } = opts
  - if (icon) classes += ' button--icon'
  - if (iconOnly) classes += ' button--icon-only'
  - if (arrow) classes += ' button--arrow'

  each item in styles
    - classes+= ` button--${item}`
    - if (item === 'sm' || item === 'md' || item === 'lg' || item === 'xl') hasSize = true
    - if (['primary', 'secondary', 'third', 'nav', 'on-dark', 'on-light', 'ghost-gold'].includes(item)) hasVariant = true

  - if (!hasSize) classes+= ` button--${defaultSize}`
  - if (!hasVariant) classes+= ` button--primary`

  mixin _ButtonInner()
    if icon
      img.button_icon(src=icon, alt=iconAlt || text)
    if !iconOnly && text
      span.button_text= text
    if arrow
      span(class=`button_arrow button_arrow--${arrow}` aria-hidden='true')

  if attributes.href !== undefined
    a(class=`button${classes}`)&attributes(attributes)
      +_ButtonInner()
  else
    button(type=type, class=`button${classes}`)&attributes(attributes)
      +_ButtonInner()
