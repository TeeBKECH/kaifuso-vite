header.header
  .container.header_container
    .header_mobile
      +ThemeSwitcher()
          //- {icon: 'pin', text: 'Address'},
          //- {icon: 'tel', text: 'Phone'},
    .header_left
      +NavMain()
    .header_center
      +Logo({type: 'header'})
    .header_right
      .header_contacts
        a.header_contact-item(href='https://yandex.ru/maps/-/CPEvnD0E', target='_blank', rel='noopener noreferrer nofollow')
          img.header_contact-icon(src="assets/img/location.svg", alt="Адрес")
          span.header_contact-text Шмитовский проезд 27с1
        a.header_contact-item(href="tel:+74996476888", target='_blank', rel='noopener noreferrer nofollow')
          img.header_contact-icon(src="assets/img/phone.svg", alt="Телефон")
          p.header_contact-text +7 (499) 647-68-88
        .header_socials
          +Socials([
            {icon: 'tg', text: 'Telegram'},
            {icon: 'vk', text: 'VK'},
            {icon: 'wa', text: 'WhatsApp'},
            {icon: 'max', text: 'Max'}
          ])(class='socials--header')
      +ThemeSwitcher()
    .header_mobile.header_mobile--right
      
      +Burger({fn: 'mobile-menu'})

