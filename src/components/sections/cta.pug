// CTA Form
section.cta(class=[page.page_class === 'contacts' ? 'cta--contacts' : '', page.page_class === 'meropriyaiya' ? 'cta--meropriyaiya' : ''].filter(Boolean).join(' '), data-aos="fade-up", data-aos-duration="1000")
  if (page.page_class !== 'contacts')
    .cta_bg
      img(src='assets/img/cta-bg.webp', alt='CTA')
      .cta_bg_overlay
  .container.cta_container
    .cta_content
      if (page.page_class === 'contacts')
        h2.cta_title.title.title-h2 Форма обратной связи
      else if (page.page_class === 'meropriyaiya')
        h2.cta_title.title.title-h2 Забронируйте комплекс<br />под ваше мероприятие
      else
        h2.cta_title.title.title-h2 Закрытие комплекса<br />под ваше мероприятие
    .cta_form
      form.form(action="#", class=[page.page_class === 'contacts' ? 'form--contacts' : '', page.page_class === 'meropriyaiya' ? 'form--meropriyaiya' : ''].filter(Boolean).join(' '))
        .form_controls
          .form_control
            input.form_input(type='text', name='name', placeholder='Ваше имя...', )
          .form_control
            input.form_input.form_input-tel(type='tel', name='tel', placeholder='+7 (___) ___-__-__',)
          if (page.page_class === 'meropriyaiya')
            .form_control
              input.form_input(type='text', name='event_date', placeholder='Дата мероприятия', autocomplete='off')
          .form_control
            if (page.page_class === 'meropriyaiya')
              +Button('Отправить', ['secondary', 'lg', 'fw'], 'submit')(class='form_submit')
            else
              +Button('Заказать Звонок', ['secondary', 'lg', 'fw'], 'submit')(class='form_submit')
        .form_controls.form_controls--alt
          .form_control
            label.form_privacy
              input.form_privacy-checkbox(type='checkbox', name='privacy', required)
              span.form_privacy-text
                | Я согласен(а) с 
                a(href='privacy.html') политикой конфиденциальности
                |  и даю согласие на обработку персональных данных