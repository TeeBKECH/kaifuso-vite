//- Миксин секции обрядов/программ
//- @param {string} title - заголовок секции
//- @param {array} items - массив обрядов/программ (при 1 — одна featured-карточка; при нескольких — все в слайдере как featured)
//- @param {string} cardMixin - название миксина для карточки ('RitualCard' или 'SpaCard')
mixin RitualsSection(props)
  - const {title = '', items = [], cardMixin = 'RitualCard'} = props
  - const hasMultiple = items.length > 1
  
  section.section.section--rituals
    .container.section_container
      +SectionTitle({
        title: title,
        size: 'lg',
        type: 'center'
      })
      .rituals_content
        if items.length === 1
          .rituals_featured
            if cardMixin === 'RitualCard'
              +RitualCard(Object.assign({}, items[0], {featured: true}))
            else if cardMixin === 'SpaCard'
              +SpaCard(items[0])
        
        else if hasMultiple
          .rituals_slider
            .rituals_slider-wrapper
              .rituals_items
                each item in items
                  //- .rituals_item
                  if cardMixin === 'RitualCard'
                    +RitualCard(Object.assign({}, item, {featured: true}))
                  else if cardMixin === 'SpaCard'
                    +SpaCard(item)
              .swiper_nav.rituals_nav
                +BtnIcon({
                  icon: 'assets/img/arrow_left.svg',
                  styles: ['swiper_nav--light', 'lg']
                })(class=`swiper_nav_item-prev rituals_nav-prev`)
                +BtnIcon({
                  icon: 'assets/img/arrow_right.svg',
                  styles: ['swiper_nav--light', 'lg']
                })(class=`swiper_nav_item-next rituals_nav-next`)
